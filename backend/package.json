{
    "name": "veiled-markets-backend",
    "version": "1.0.0",
    "description": "Backend indexer service for Veiled Markets",
    "type": "module",
    "scripts": {
        "index": "tsx src/index-markets.ts",
        "index:watch": "tsx watch src/index-markets.ts",
        "governance": "tsx src/governance-indexer.ts",
        "governance:watch": "tsx watch src/governance-indexer.ts",
        "disputes": "tsx src/dispute-indexer.ts",
        "disputes:watch": "tsx watch src/dispute-indexer.ts",
        "oracle": "tsx src/pyth-oracle.ts --serve",
        "oracle:watch": "tsx watch src/pyth-oracle.ts --serve",
        "oracle:dev": "tsx src/pyth-oracle.ts",
        "build": "tsc",
        "dev": "tsx watch src/index-markets.ts"
    },
    "dependencies": {
        "eventsource": "^3.0.7",
        "node-fetch": "^3.3.2"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    }
}
