# ============================================================================
# VEILED MARKETS - Vercel Environment Variables Template
# ============================================================================
# Copy these to Vercel Dashboard → Settings → Environment Variables
# (apply to Production, Preview, and Development scopes as needed).
#
# Last contract redeploy: 2026-04-08 (v6 post-audit hardening — Bug A/B/C/D
# fixes + initiate_escalation hardening). Active contracts: v37/v7/v14/v6.
# ============================================================================

# =========================
# NETWORK CONFIGURATION
# =========================
VITE_NETWORK=testnet
VITE_ALEO_RPC_URL=https://api.explorer.provable.com/v1/testnet
VITE_EXPLORER_URL=https://testnet.explorer.provable.com

# =========================
# PROGRAM CONFIGURATION (active v6 post-audit hardening, deployed 2026-04-08)
# =========================
# Markets:
#   - veiled_markets_v37.aleo       — ALEO market (Bug B/D fixes + assert_disputed)
#   - veiled_markets_usdcx_v7.aleo  — USDCX market (Bug B/D fixes + assert_disputed)
#   - veiled_markets_usad_v14.aleo  — USAD market (Bug B/D fixes + assert_disputed)
# Governance:
#   - veiled_governance_v6.aleo     — Bug A/C fixes + initiate_escalation split
VITE_PROGRAM_ID=veiled_markets_v37.aleo
VITE_CREDITS_PROGRAM_ID=credits.aleo
VITE_USDCX_PROGRAM_ID=test_usdcx_stablecoin.aleo
VITE_USAD_PROGRAM_ID=veiled_markets_usad_v14.aleo
VITE_USDCX_MARKET_PROGRAM_ID=veiled_markets_usdcx_v7.aleo
VITE_GOVERNANCE_PROGRAM_ID=veiled_governance_v6.aleo
VITE_PARLAY_PROGRAM_ID=veiled_parlay_v3.aleo

# Note: legacy program IDs (v36/v6/v13/v5 and earlier) have been removed.
# Frontend now only interacts with the active v37/v7/v14/v6 contracts.
# Markets created on older contract versions are no longer surfaced in the UI.

# =========================
# APP CONFIGURATION
# =========================
VITE_APP_NAME=Veiled Markets
VITE_APP_DESCRIPTION=Privacy-Preserving Prediction Markets on Aleo
VITE_APP_URL=https://veiledmarkets.xyz

# =========================
# WALLET CONFIGURATION
# =========================
VITE_ENABLE_DEMO_MODE=false
VITE_DEFAULT_WALLET=shield

# =========================
# FEATURE FLAGS
# =========================
VITE_ENABLE_CREATE_MARKET=true
VITE_ENABLE_BETTING=true
VITE_SHOW_TESTNET_BANNER=true
VITE_DEBUG=false

# =========================
# SUPABASE (cross-device bet persistence, market discovery, dispute mirror)
# =========================
# Required tables: user_bets, pending_bets, commitment_records,
# market_registry, market_disputes (from supabase/create_market_disputes_table.sql)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# =========================
# IPFS / PINATA (market thumbnails + question text)
# =========================
VITE_PINATA_JWT=your-pinata-jwt
VITE_PINATA_GATEWAY=https://your-gateway.mypinata.cloud

# =========================
# OPTIONAL: ANALYTICS & MONITORING
# =========================
# VITE_ANALYTICS_ID=
# VITE_SENTRY_DSN=

# =========================
# NOTES
# =========================
# 1. Update VITE_APP_URL with your actual Vercel URL.
# 2. For production, set VITE_NETWORK=mainnet (markets are testnet-only today).
# 3. Never commit real private keys.
# 4. All variables must start with VITE_ to be exposed to the browser.
# 5. Backend dispute-indexer (deployed separately, NOT on Vercel) needs:
#       SUPABASE_SERVICE_ROLE_KEY (server-only, not VITE_ prefixed)
#       DISPUTE_INDEXER_START_BLOCK
#       DISPUTE_POLL_INTERVAL_MS
#       VITE_PROGRAM_ID, VITE_USDCX_MARKET_PROGRAM_ID, VITE_USAD_PROGRAM_ID
