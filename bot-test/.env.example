# ============================================================================
# Telegram bot configuration — copy to .env and fill in your values
# ============================================================================

# ── Telegram ─────────────────────────────────────────────────────────────────
# Get a bot token from @BotFather: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:AAExampleBotTokenFromBotFatherReplaceThis

# Comma-separated list of authorized Telegram user IDs (numeric).
# Get your ID by messaging @userinfobot. Only these IDs can issue bet commands.
# Leave empty during smoke test to allow any user (NOT for production).
TELEGRAM_AUTHORIZED_IDS=123456789,987654321

# ── Aleo wallet (bettor) ─────────────────────────────────────────────────────
# Aleo private key for the bettor account. KEEP SECRET — never commit .env.
# Format: APrivateKey1zk...
ALEO_PRIVATE_KEY=APrivateKey1zkExampleReplaceWithYourTestnetKeyHere
ALEO_ADDRESS=aleo1exampleReplaceWithYourTestnetAddressHere

# ── Veiled Markets Turbo backend ─────────────────────────────────────────────
# Turbo oracle URL — runs pyth-oracle.ts.
# Production (live, default): https://evonft.xyz
# Local development:          http://localhost:4090
TURBO_ORACLE_URL=https://evonft.xyz

# Network — testnet for now, mainnet later
ALEO_NETWORK=testnet

# Optional: Supabase indexer for win-rate stats
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# ── Bot behavior ─────────────────────────────────────────────────────────────
# Set to 1 to skip actual on-chain broadcast (safe for testing)
DRY_RUN=1

# Default symbol when user issues /bet without specifying
DEFAULT_SYMBOL=BTC

# Default bet amount in ALEO when user doesn't specify
DEFAULT_AMOUNT=0.5

# Polling interval (ms) for new market detection — used by /watch command
POLL_INTERVAL_MS=15000
